# ============================================================
# FlowOps 私有化部署配置（复制为 .env 后按需修改）
#   cp .env.example .env
# 标 ⚠️ 的项请务必改成你自己的值再上线
# ============================================================

PORT=3000

# ---------- 数据库（默认随 compose 起的 PostgreSQL）----------
# 信创环境：Kingbase(人大金仓) 兼容 PG，可保持 DATABASE_TYPE=postgres，把 HOST 指向你的库
DATABASE_TYPE=postgres
DATABASE_HOST=flowops-db
DATABASE_PORT=5432
DATABASE_NAME=flowops
DATABASE_USER=flowops
DATABASE_PASSWORD=flowops_db_pwd   # ⚠️ 改成强密码，并与下方一致

# ---------- 数据不出域 / 合规 ----------
DISABLE_FLOWISE_TELEMETRY=true     # 关闭遥测/匿名统计上报（私有化必须）
STORAGE_TYPE=local                 # 文件存本地卷，不上云
SECRETKEY_STORAGE_TYPE=local       # 加密密钥本地存储

# ---------- 密钥（⚠️ 全部改成随机串：openssl rand -hex 32）----------
FLOWISE_SECRETKEY_OVERWRITE=PLEASE_CHANGE_ME_secretkey
JWT_AUTH_TOKEN_SECRET=PLEASE_CHANGE_ME_jwt_auth
JWT_REFRESH_TOKEN_SECRET=PLEASE_CHANGE_ME_jwt_refresh
EXPRESS_SESSION_SECRET=PLEASE_CHANGE_ME_session
TOKEN_HASH_SECRET=PLEASE_CHANGE_ME_token_hash

# ---------- 隐藏已弃用节点（FlowOps 已用国产/更优节点替代，共 47 个）----------
DISABLED_NODES=airtableAgent,conversationalAgent,anthropicAgentLlamaIndex,openAIToolAgentLlamaIndex,openAIAssistant,reactAgentChat,reactAgentLLM,getApiChain,openApiChain,postApiChain,multiPromptChain,multiRetrievalQAChain,retrievalQAChain,vectorDBQAChain,azureChatOpenAI_LlamaIndex,chatAnthropic_LlamaIndex,chatMistral_LlamaIndex,chatOllama_LlamaIndex,chatOpenAI_LlamaIndex,chatTogetherAI_LlamaIndex,chatGroq_LlamaIndex,azureOpenAIEmbeddingsLlamaIndex,openAIEmbedding_LlamaIndex,contextChatEngine,simpleChatEngine,queryEngine,subQuestionQueryEngine,awsBedrock,azureOpenAI,cohere,fireworks,googlevertexai,huggingFaceInference_LLMs,ibmWatsonx,ollama,openAI,sambanova,togetherAI,agentMemory,compactrefineLlamaIndex,refineLlamaIndex,simpleResponseBuilderLlamaIndex,treeSummarizeLlamaIndex,queryEngineToolLlamaIndex,pineconeLlamaIndex,simpleStoreLlamaIndex,vectaraUpload

# ---------- 支付沙箱（支付宝 / 微信支付）----------
# PAYMENT_NOTIFY_BASE_URL 必须是支付宝/微信能访问到的公网 HTTPS 地址，例如 https://pay.example.com
PAYMENT_NOTIFY_BASE_URL=

# 支付宝沙箱：私钥/公钥可使用一行字符串，换行写成 \n
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_GATEWAY=https://openapi.sandbox.dl.alipaydev.com/gateway.do

# 微信支付 v3 Native 沙箱/商户配置：所有密钥只读环境变量，不写入前端
WECHAT_MCH_ID=
WECHAT_APP_ID=
WECHAT_PRIVATE_KEY=
WECHAT_SERIAL_NO=
WECHAT_APIV3_KEY=
WECHAT_PLATFORM_CERT=
# WECHAT_GATEWAY=https://api.mch.weixin.qq.com

# ---------- 可选 ----------
# CORS_ORIGINS=*
# IFRAME_ORIGINS=*
# 首次访问 /signin 注册的第一个账号即为管理员（FlowOps 3.x 采用账号体系，非 basic auth）
