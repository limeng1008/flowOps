                "inputAnchors": [],
                "inputs": {
                    "llmModel": "chatZhipuAI",
                    "llmMessages": [
                        {
                            "role": "system",
                            "content": "<p>你是一名专业会议纪要助手，擅长从零散会议记录、速记和口语化表达中提炼摘要、明确决议、行动项和未决问题。请忠于用户提供的原始记录，不臆造未提及的信息；无法确认的负责人、日期或结论请标注“待确认”。输出应简洁、客观、可执行，适合直接发给团队复盘。</p>"
                        },
                        {
                            "role": "user",
                            "content": "<p>请根据以下信息整理中文会议纪要：</p><p>会议主题：<span class=\"variable\" data-type=\"mention\" data-id=\"$form.meetingTopic\" data-label=\"$form.meetingTopic\">{{ $form.meetingTopic }}</span></p><p>参会人：<span class=\"variable\" data-type=\"mention\" data-id=\"$form.attendees\" data-label=\"$form.attendees\">{{ $form.attendees }}</span></p><p>原始记录/速记：<span class=\"variable\" data-type=\"mention\" data-id=\"$form.rawNotes\" data-label=\"$form.rawNotes\">{{ $form.rawNotes }}</span></p><p>会议日期：<span class=\"variable\" data-type=\"mention\" data-id=\"$form.meetingDate\" data-label=\"$form.meetingDate\">{{ $form.meetingDate }}</span></p><p>要求：从原始记录中提炼会议摘要、明确决议、待办事项和未决问题。行动项需要包含任务、负责人和截止时间；如果记录中没有明确负责人或截止时间，请写“待确认”。不要补写原始记录里没有的信息。</p>"
                        }
                    ],
                    "llmEnableMemory": false,
                    "llmReturnResponseAs": "userMessage",
                    "llmStructuredOutput": [
                        {
                            "key": "summary",
                            "type": "string",
                            "enumValues": "",
                            "jsonSchema": "",
                            "description": "会议摘要，概括讨论背景、主要结论和整体进展"
                        },
                        {
                            "key": "decisions",
                            "type": "stringArray",
                            "enumValues": "",
                            "jsonSchema": "",
                            "description": "会议中已经明确的决议或共识"
                        },
                        {
                            "key": "actionItems",
                            "type": "jsonArray",
                            "enumValues": "",
                            "jsonSchema": "{\n    \"task\": {\n        \"type\": \"string\",\n        \"description\": \"待办任务\"\n    },\n    \"owner\": {\n        \"type\": \"string\",\n        \"description\": \"负责人；未明确则写待确认\"\n    },\n    \"dueDate\": {\n        \"type\": \"string\",\n        \"description\": \"截止时间；未明确则写待确认\"\n    }\n}",
                            "description": "会议后需要跟进的行动项，每项包含任务、负责人和截止时间"
                        },
                        {
                            "key": "openIssues",
                            "type": "stringArray",
                            "enumValues": "",
                            "jsonSchema": "",
                            "description": "会议中尚未解决或需要后续确认的问题"
                        }
                    ],
                    "llmUpdateState": "",
                    "llmModelConfig": {
                        "cache": "",
                        "modelName": "glm-4.5",
                        "customModelName": "",
                        "temperature": 0.8,
                        "streaming": true,
                        "maxTokens": "",
                        "topP": "",
                        "frequencyPenalty": "",
                        "presencePenalty": "",
                        "timeout": "",
                        "stopSequence": "",
                        "baseOptions": "",
                        "llmModel": "chatZhipuAI"
                    }
