                                "sessionLabel": "AI 客服转人工",
                                "toolName": "human_handoff",
                                "toolDescription": "",
                                "credential": "",
                                "agentSelectedTool": "humanHandoff"
                            }
                        }
                    ],
                    "agentKnowledgeDocumentStores": "",
                    "agentKnowledgeVSEmbeddings": "",
                    "agentEnableMemory": true,
                    "agentMemoryType": "allMessages",
                    "agentUserMessage": "",
                    "agentReturnResponseAs": "userMessage",
                    "agentUpdateState": "",
                    "agentModelConfig": {
                        "cache": "",
                        "modelName": "glm-4.5",
                        "customModelName": "",
                        "temperature": 0.3,
                        "streaming": true,
                        "maxTokens": "",
                        "topP": "",
                        "frequencyPenalty": "",
                        "presencePenalty": "",
                        "timeout": "",
                        "stopSequence": "",
                        "baseOptions": "",
                        "agentModel": "chatZhipuAI"
                    }
