                "inputAnchors": [],
                "inputs": {
                    "llmModel": "chatGoogleGenerativeAI",
                    "llmMessages": [
                        {
                            "role": "system",
                            "content": "<p>You are a senior presentation deck strategist. Create boardroom-ready, logically sequenced slide decks for AI Agent workflow management, enterprise software, internal training, product strategy, sales enablement, and research briefings.</p><p>Return concise, presentation-ready content. Make every slide useful: one clear idea, crisp bullets, speaker notes, and visual direction. Do not claim that a .pptx file has been generated; this workflow produces a structured deck plan that can later be exported by a PPTX generation tool.</p>"
                        },
                        {
                            "role": "user",
                            "content": "<p>Create a presentation deck plan using these inputs:</p><p>Topic: <span class=\"variable\" data-type=\"mention\" data-id=\"$form.topic\" data-label=\"$form.topic\">{{ $form.topic }}</span></p><p>Audience: <span class=\"variable\" data-type=\"mention\" data-id=\"$form.audience\" data-label=\"$form.audience\">{{ $form.audience }}</span></p><p>Slide count: <span class=\"variable\" data-type=\"mention\" data-id=\"$form.slideCount\" data-label=\"$form.slideCount\">{{ $form.slideCount }}</span></p><p>Tone / style: <span class=\"variable\" data-type=\"mention\" data-id=\"$form.tone\" data-label=\"$form.tone\">{{ $form.tone }}</span></p><p>Source materials: <span class=\"variable\" data-type=\"mention\" data-id=\"$form.materials\" data-label=\"$form.materials\">{{ $form.materials }}</span></p><p>Requirements:</p><p>1. Use the requested slide count when possible.</p><p>2. Include an executive-level narrative arc.</p><p>3. For each slide include title, objective, key message, bullets, speaker notes, and visual suggestion.</p><p>4. Keep the answer practical enough for a designer or PPTX generation tool to produce the deck.</p>"
                        }
                    ],
                    "llmEnableMemory": false,
                    "llmReturnResponseAs": "userMessage",
                    "llmStructuredOutput": [
                        {
                            "key": "deckTitle",
                            "type": "string",
                            "enumValues": "",
                            "jsonSchema": "",
                            "description": "Short title for the presentation deck"
                        },
                        {
                            "key": "executiveSummary",
                            "type": "string",
                            "enumValues": "",
                            "jsonSchema": "",
                            "description": "One-paragraph summary of the deck"
                        },
                        {
                            "key": "targetAudience",
                            "type": "string",
                            "enumValues": "",
                            "jsonSchema": "",
                            "description": "Audience and decision context"
                        },
                        {
                            "key": "narrativeArc",
                            "type": "stringArray",
                            "enumValues": "",
                            "jsonSchema": "",
                            "description": "High-level story beats across the deck"
                        },
                        {
                            "key": "slides",
                            "type": "jsonArray",
                            "enumValues": "",
                            "jsonSchema": "{\n    \"slideNumber\": {\n        \"type\": \"number\",\n        \"description\": \"Slide number in the deck\"\n    },\n    \"title\": {\n        \"type\": \"string\",\n        \"description\": \"Presentation-ready slide title\"\n    },\n    \"objective\": {\n        \"type\": \"string\",\n        \"description\": \"What this slide needs to accomplish\"\n    },\n    \"keyMessage\": {\n        \"type\": \"string\",\n        \"description\": \"The single most important message of the slide\"\n    },\n    \"bullets\": {\n        \"type\": \"array\",\n        \"items\": {\n            \"type\": \"string\"\n        },\n        \"description\": \"Three to five concise bullet points\"\n    },\n    \"speakerNotes\": {\n        \"type\": \"string\",\n        \"description\": \"Short presenter talk track for the slide\"\n    },\n    \"visualSuggestion\": {\n        \"type\": \"string\",\n        \"description\": \"Suggested chart, diagram, screenshot, table, or visual treatment\"\n    }\n}",
                            "description": "Detailed slide-by-slide plan"
                        },
                        {
                            "key": "designDirection",
                            "type": "string",
                            "enumValues": "",
                            "jsonSchema": "",
                            "description": "Recommended visual style, palette, layout rhythm, and asset direction"
                        },
                        {
                            "key": "deliveryTips",
                            "type": "stringArray",
                            "enumValues": "",
                            "jsonSchema": "",
                            "description": "Practical presenter tips and rehearsal notes"
                        }
                    ],
