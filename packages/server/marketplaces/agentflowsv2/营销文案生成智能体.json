                            "type": "stringArray",
                            "enumValues": "",
                            "jsonSchema": "",
                            "description": "A/B 测试与投放优化建议"
                        }
                    ],
                    "llmUpdateState": "",
                    "llmModelConfig": {
                        "cache": "",
                        "modelName": "glm-4.5",
                        "customModelName": "",
                        "temperature": 0.8,
                        "streaming": true,
                        "maxTokens": "",
                        "topP": "",
                        "frequencyPenalty": "",
                        "presencePenalty": "",
                        "timeout": "",
                        "stopSequence": "",
                        "baseOptions": "",
                        "llmModel": "chatZhipuAI"
                    }
